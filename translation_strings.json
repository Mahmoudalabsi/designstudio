  "faq.html": {
    "title": {
      "ar": "الأسئلة الشائعة - مصمم الصور",
      "key": "faq_title"
    },
    "h1": {
      "ar": "الأسئلة الشائعة",
      "key": "faq_h1"
    },
    "page_desc": {
      "ar": "إجابات على أكثر الأسئلة شيوعاً.",
      "key": "faq_desc"
    },
    "q1_h3": {
      "ar": "ما هو تطبيق مصمم الصور؟",
      "key": "faq_q1"
    },
    "q1_p": {
      "ar": "مصمم الصور هو تطبيق تصميم عربي يتيح لك إنشاء تصاميم احترافية بسهولة باستخدام قوالب وفيرة وأدوات متقدمة.",
      "key": "faq_a1"
    },
    "q2_h3": {
      "ar": "هل التطبيق مجاني؟",
      "key": "faq_q2"
    },
    "q2_p": {
      "ar": "نعم، التطبيق مجاني للتحميل والاستخدام مع قوالب مجانية. يمكن الاشتراك في الخطة premium للحصول على قوالب وحقوق إضافية.",
      "key": "faq_a2"
    },
    "q3_h3": {
      "ar": "كيف أحفظ تصميمي؟",
      "key": "faq_q3"
    },
    "q3_p": {
      "ar": "بعد الانتهاء من التصميم، اضغط على زر \"حفظ\" واختر الصيغة المطلوبة (PNG أو JPG).",
      "key": "faq_a3"
    },
    "q4_h3": {
      "ar": "هل يمكنني استخدام التصاميم تجارياً؟",
      "key": "faq_q4"
    },
    "q4_p": {
      "ar": "نعم، بمجرد الاشتراك في التطبيق، تصبح التصاميم ملكاً لك ويمكن استخدامها تجارياً.",
      "key": "faq_a4"
    },
    "q5_h3": {
      "ar": "كيف أتواصل مع الدعم؟",
      "key": "faq_q5"
    },
    "q5_p": {
      "ar": "يمكنكم التواصل معنا عبر نموذج التواصل في صفحة تواصل معنا أو عبر وسائل التواصل الاجتماعي.",
      "key": "faq_a5"
    }
  },

