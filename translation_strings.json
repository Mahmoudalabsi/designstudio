    "section_4_p": {
      "ar": "شعارات Google Play وApple وSamsung وغيرها من العلامات التجارية هي ملك لأصحابها. لا نطالب بملكيتها.",
      "key": "copyright_section_4_body"
    },
    "section_5_h2": {
      "ar": "5. المحتوى الذي ينشئه المستخدمون",
      "key": "copyright_section_5_title"
