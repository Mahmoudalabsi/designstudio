# ───────────────────────────────────────────────────────────
#  ملف .gitignore - مصمم الصور
# ───────────────────────────────────────────────────────────

# ملفات البناء المحلية لـ Netlify CLI
.netlify/

# ملفات npm
node_modules/

# ملفات Python
__pycache__/
*.pyc
*.pyo

# ملفات النظام
.DS_Store
Thumbs.db

# ملفات محرر الأكواد
.vscode/
.idea/
*.swp
*.swo

# ملفات مؤقتة
*.log
*.tmp
